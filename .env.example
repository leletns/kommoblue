# =============================================
# KOMMO CRM (amoCRM)
# =============================================
# Subdomínio da sua conta Kommo (ex: minhaempresa em minhaempresa.kommo.com)
KOMMO_SUBDOMAIN=minhaempresa

# OAuth2 — crie um integration em https://www.kommo.com/developers/
KOMMO_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
KOMMO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL de callback OAuth (deve ser público — use ngrok em dev)
# ex: https://meuservidor.com/auth/kommo/callback
KOMMO_REDIRECT_URI=https://seu-servidor.com/auth/kommo/callback

# Tokens OAuth (preenchidos automaticamente após "npm run setup")
KOMMO_ACCESS_TOKEN=
KOMMO_REFRESH_TOKEN=
KOMMO_TOKEN_EXPIRES_AT=

# =============================================
# ANTHROPIC (Claude AI)
# =============================================
ANTHROPIC_API_KEY=sk-ant-...

# Modelo Claude a usar (recomendado: claude-opus-4-7)
AI_MODEL=claude-opus-4-7

# =============================================
# CONFIGURAÇÃO DO AGENTE
# =============================================
# Idioma das análises e notas da IA (padrão: pt-BR)
AGENT_LANGUAGE=pt-BR

# A IA deve enviar mensagem de resposta ao cliente via Kommo? (true/false)
AGENT_AUTO_REPLY=false

# Se true, a IA só envia resposta depois de aprovação humana
AGENT_REPLY_REQUIRES_APPROVAL=true

# Quantidade máxima de mensagens históricas para enviar ao contexto da IA
AI_CONTEXT_MAX_MESSAGES=50

# =============================================
# SERVIDOR
# =============================================
PORT=3000
NODE_ENV=development

# Chave secreta para verificar autenticidade dos webhooks do Kommo
# (qualquer string aleatória — configure igual no painel Kommo)
WEBHOOK_SECRET=minha-chave-secreta-aqui

# =============================================
# ARMAZENAMENTO DE TOKENS
# =============================================
# Caminho para arquivo de tokens persistentes (relativo à raiz do projeto)
TOKEN_STORE_PATH=./data/tokens.json
